            "import": "./dist/index.js"
        }
    },
    "dependencies": {
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@freehour/eslint-rules": "^1.0.19",
        "ajv": "^8.20.0",
        "bun-types": "^1.3.13",
        "eslint": "9.39.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4"
    }
}