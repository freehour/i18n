{
    "name": "@freehour/i18n",
    "private": false,
    "displayName": "i18n",
    "description": "Simple i18n translation library based on Intl.",
    "version": "0.1.2",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/freehour/i18n.git"
    },
    "scripts": {
        "lint": "eslint ./lib --ext ts",
        "build": "bun run lint && tsc && vite build"
